# ===== Body Management System - Git Ignore v2.0 =====
# 
# CRITICAL: NEVER COMMIT USER DATA OR CONFIGURATIONS
# This protects your API keys, health data, and personal information

# ============================================
# USER DATA (CRITICAL - PRIVACY)
# ============================================

# User-specific data directory
../../body-management-data/
../../body-management-data/**/*

# Config files with secrets (extra protection)
config.json
config.local.json
skills/*/config.json
skills/*/config.local.json

# Sensitive credential files
*.key
*.secret
*.pem
.env
.env.local
.env.*.local

# ============================================
# PYTHON ARTIFACTS
# ============================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
develop-eggs/
dist/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.manifest
*.spec

# ============================================
# VIRTUAL ENVIRONMENTS  
# ============================================

env/
venv/
ENV/
.venv/
.python-version

# ============================================
# IDE & EDITOR FILES
# ============================================

.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.project
.settings/
.classpath

# ============================================
# LOGGING FILES
# ============================================

*.log
logs/
output.log
debug.log

# ============================================
# TESTING
# ============================================

.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ============================================
# BACKUP & TEMPORARY FILES
# ============================================

*.bak
*.backup
*.old
tmp/
temp/
.tmp/
.temp/
.scratch/

# ============================================
# OPENCLAW WORKSPACE SPECIFIC
# ============================================

# Skip all body-management-data except docs
!../../body-management-data/README.md
!../../body-management-data/DATA_STORAGE.md
!../../body-management-data/MIGRATION.md
!../../body-management-data/VERSION

# ============================================
# DOCUMENTATION BUILD OUTPUTS
# ============================================

docs/_build/
site/
_build/
html/
